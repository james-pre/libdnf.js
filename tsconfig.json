{
	"compilerOptions": {
		"module": "NodeNext",
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleResolution": "NodeNext",
		"rootDir": "lib",
		"outDir": "dist",
		"strict": true,
		"declaration": true,
		"allowArbitraryExtensions": true,
		"types": ["node"]
	},
	"include": ["lib/**/*.ts"],
	"exclude": ["node_modules"],
	"typedocOptions": {
		"entryPoints": ["./lib/index.ts"],
		"out": "docs",
		"name": "libdnf"
	}
}
